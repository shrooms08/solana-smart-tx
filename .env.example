# Copy to `.env` and fill in. NEVER commit the real `.env`.

# Solana JSON-RPC endpoint
RPC_URL=https://api.mainnet-beta.solana.com

# Yellowstone gRPC (Dragon's Mouth) endpoint + optional auth token
YELLOWSTONE_ENDPOINT=https://your-grpc-endpoint:10000
YELLOWSTONE_X_TOKEN=

# Jito block-engine REGIONAL base URL — set this to the region nearest your
# infra/operator location for lowest submission latency (<30ms delivery per
# Jito's docs). The global `mainnet.block-engine.jito.wtf` adds latency vs. a
# matched region. Regions: amsterdam, frankfurt, ny, tokyo, slc, london, dublin.
# Our infra is in Amsterdam, so the recommended value is the Amsterdam endpoint:
JITO_BLOCK_ENGINE_URL=https://amsterdam.mainnet.block-engine.jito.wtf

# Jito rate-limit budget (requests/sec) shared across ALL block-engine calls
# (getTipAccounts, sendBundle, getInflightBundleStatuses, getBundleStatuses).
# The anonymous public endpoint is limited to 1 req/sec/IP/region — exceeding it
# returns HTTP 429 ("Network congested / globally rate limited") and the bundle
# is dropped at ingress (getInflightBundleStatuses => Invalid). Leave at 1 unless
# you have an auth uuid (then set 5). Default 1.
JITO_RPS=1

# Optional Jito auth UUID. When set, sent as the `x-jito-auth` header on every
# block-engine request, raising the rate limit from 1 to 5 req/sec. Obtain one by
# registering / requesting access from Jito (https://www.jito.wtf, their Discord
# #searcher channel, or support@jito.wtf) — they whitelist your IP/UUID. Leave
# blank for the anonymous 1-RPS path.
JITO_AUTH_UUID=

# Auction-aware optimization (OFF by default). Validators are either plain Jito
# (Block Engine: auction scored on tips/CU) or BAM (also runs a BAM Node auction
# scored on (tips + priority_fees)/CU). When BAM_PRIORITY_FEE_ENABLED=1 and the
# target leader runs BAM, the submitter adds a ComputeBudget SetComputeUnitPrice
# instruction of BAM_PRIORITY_FEE_MICROLAMPORTS micro-lamports/CU so the bundle
# competes on priority fees too. Non-BAM leaders are unaffected. Leave disabled
# until you've sized the fee against landed-bundle data.
#
# The priority fee charged = ceil(price_microlamports × cu_limit / 1e6) lamports,
# and BAM scores (tips + priority_fees) / requested_CU. BAM_PRIORITY_FEE_CU_LIMIT
# pins the requested CU (the denominator) just above our payload tx's real usage
# (~8.4k CU: memo ~7.9k + 2 compute-budget ix + self-transfer), making both the
# fee and the ratio predictable instead of the ~200k×N-instruction default.
# Example: price=950000, cu_limit=10000 -> fee = 950000×10000/1e6 = 9500 lamports
# (≈ one tip), and (tips+prio)/CU ≈ (9500+9500)/10000 ≈ 1.9 lamports/CU.
BAM_PRIORITY_FEE_ENABLED=0
BAM_PRIORITY_FEE_MICROLAMPORTS=0
BAM_PRIORITY_FEE_CU_LIMIT=10000

# Lamports for the wallet->wallet self-transfer added to the payload tx. This
# gives the bundle real account-state-changing content so Jito's auction
# schedules it (a tip-only no-op bundle is deprioritized). Free beyond the
# per-signature fee since the wallet pays itself. Default 1000.
SELF_TRANSFER_LAMPORTS=1000

# Path to the wallet keypair JSON (kept out of git)
WALLET_KEYPAIR_PATH=./wallet-keypair.json

# Anthropic API key for the reasoning agent
ANTHROPIC_API_KEY=

# Optional: tracing verbosity
RUST_LOG=info
